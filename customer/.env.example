# Swiftry Customer - Environment Variables Example
# Copy to .env and fill values. NEVER commit .env with real keys.
# For production, use --dart-define instead of .env

# API
API_BASE_URL=https://api.swiftree.com/v1
API_STAGING_URL=https://staging-api.swiftree.com/v1
FLAVOR=development

# Google Maps - Get from https://console.cloud.google.com/apis
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Feature flags
ENABLE_MOCK_SIMULATION=true

# How to run:
# flutter run --dart-define=GOOGLE_MAPS_API_KEY=YOUR_KEY --dart-define=FLAVOR=development --dart-define=API_BASE_URL=https://staging-api.swiftree.com/v1

# Or with env file (requires flutter_dotenv already added in main.dart):
# flutter run
